# Supabase (Self-hosted on Coolify)
# In Coolify, use references: ${SERVICE_URL_SUPABASEKONG}
# REQUIRED
NEXT_PUBLIC_SUPABASE_URL=
# REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Comma-separated allowlist for server-side Origin checks (mutating API routes)
# Example: https://app.example.com,https://admin.example.com
# REQUIRED IN PRODUCTION FOR CUSTOM DOMAINS
ALLOWED_ORIGINS=
