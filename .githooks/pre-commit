#!/bin/sh
# ═══════════════════════════════════════════════════════════════
#  ⚡ Nullar pre-commit-hook ⚡
# ═══════════════════════════════════════════════════════════════

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  ⚡ Nullar pre-commit-hook ⚡"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo " ⚡ Running pre-commit checks..."
echo ""

# ANSI colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Run Prettier check first (fastest)
echo " ${BLUE}🎨 Checking formatting...${NC}"
pnpm run format:check
if [ $? -ne 0 ]; then
    echo " ${YELLOW}Formatting issues found, fixing...${NC}"
    pnpm run format
fi

# Run ESLint
echo " ${BLUE}🔍 Running ESLint...${NC}"
pnpm run lint
if [ $? -ne 0 ]; then
    echo " ${YELLOW}Lint issues found, auto-fixing...${NC}"
    pnpm run lint:fix
    # Re-run lint to verify
    pnpm run lint
    if [ $? -ne 0 ]; then
        echo ""
        echo " ${RED}❌ LINT FAILED${NC}"
        echo " ${YELLOW}Fix remaining lint errors manually${NC}"
        echo " ${YELLOW}Modified files are NOT staged - safe to inspect${NC}"
        exit 1
    fi
fi

# Run TypeScript
echo " ${BLUE}🔦 Running TypeScript...${NC}"
pnpm run typecheck
if [ $? -ne 0 ]; then
    echo ""
    echo " ${RED}❌ TYPECHECK FAILED${NC}"
    echo " ${YELLOW}Modified files are NOT staged - safe to inspect${NC}"
    exit 1
fi

# Run tests
echo " ${BLUE}🧪 Running tests...${NC}"
pnpm run test
if [ $? -ne 0 ]; then
    echo ""
    echo " ${RED}❌ TESTS FAILED${NC}"
    echo " ${YELLOW}Modified files are NOT staged - safe to inspect${NC}"
    exit 1
fi

# All checks passed - stage modified files (auto-formatted, auto-fixed)
git add -u
echo " ✅ Files auto-formatted/fixed have been staged"

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  ${GREEN}✅ All checks passed! Ready to commit!${NC}"
echo "═══════════════════════════════════════════════════════════════"
echo ""
