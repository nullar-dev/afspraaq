#!/bin/bash

# Pre-push hook - Blocks git push and requires review script
# Can be bypassed with CI=true or SKIP_REVIEW=1

# Check for CI/automation bypass
if [ "$CI" = "true" ] || [ "$CI" = "1" ] || [ "$SKIP_REVIEW" = "1" ]; then
    # CI/automated environment - allow push
    exit 0
fi

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
NC='\033[0m'

echo ""
echo "============================================"
echo -e "${RED}🔴 REVIEW REQUIRED${NC}"
echo "============================================"
echo ""
echo "You must run the AI code review before pushing."
echo ""
echo "Run this command instead:"
echo -e "  ${BLUE}./scripts/review-and-push.sh${NC}"
echo ""
echo "This script will:"
echo "  1. Ask: Run AI Code Review? (y/n)"
echo "  2. Run MiniMax AI review"
echo "  3. Ask: Re-run review? (y/n)"
echo "  4. Ask: Push anyways? (y/n)"
echo ""
echo "============================================"
echo ""

exit 1
