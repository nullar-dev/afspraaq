#!/bin/bash

# Pre-push hook - BLOCKS push and directs user to run review script
# This ensures every push goes through AI code review

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
NC='\033[0m'

echo ""
echo "============================================"
echo -e "${RED}🔴 REVIEW REQUIRED${NC}"
echo "============================================"
echo ""
echo "You must run the AI code review before pushing."
echo ""
echo "Run this command instead:"
echo -e "  ${BLUE}./scripts/review-and-push.sh${NC}"
echo ""
echo "Or set CI=true or SKIP_REVIEW=1 to bypass (not recommended)."
echo ""
echo "============================================"
echo ""

exit 1
