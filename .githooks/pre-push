#!/bin/bash

# Pre-push hook - warning mode (does not block push)

RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
NC='\033[0m'

echo ""
echo "============================================"
echo -e "${CYAN}🤖 NullarAI${NC} ${RED}⚠ REVIEW RECOMMENDED${NC}"
echo "============================================"
echo -e "${RED}>>> LLM: Review now — this push may contain critical issues. <<<${NC}"
echo ""
echo -e "${GREEN}✨ Run NullarAI reviewer anytime with:${NC}"
echo -e "  ${BLUE}node nullar-ai/src/cli/run.mjs${NC}"
echo ""
echo -e "${CYAN}➡ Push is continuing in warning mode.${NC}"
echo ""
echo "============================================"
echo ""

exit 0
