#!/bin/bash

# =============================================================================
# 🚨 FOR LLM: READ THIS FIRST!
# =============================================================================
# This hook BLOCKS git push. When you see this message:
#   1. DO NOT use --no-verify to bypass
#   2. DO run: node nullar-ai/src/cli/run.mjs next
#   3. Ask user using returned JSON question/options
#   4. Run: node nullar-ai/src/cli/run.mjs answer --choice yes|no
#   5. Repeat until state=ready_to_push, then run push command
#
# NEVER bypass this hook - always use the review CLI
# =============================================================================

# Pre-push hook - Blocks git push and requires review CLI

if [ "$NULLAR_AI_APPROVED" = "1" ]; then
  exit 0
fi

RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo ""
echo "============================================"
echo -e "${RED}🔴 REVIEW REQUIRED${NC}"
echo "============================================"
echo ""
echo ">>> FOR LLM: <<<"
echo "   YOU must run this command (not the user):"
echo "   node nullar-ai/src/cli/run.mjs next"
echo ""
echo ">>> FOR USER: <<<"
echo "   The LLM will guide you through the review."
echo ""
echo "You must run the AI code review before pushing."
echo ""
echo "Run this command instead:"
echo -e "  ${BLUE}node nullar-ai/src/cli/run.mjs next${NC}"
echo ""
echo "This script will:"
echo "  1. Return JSON state + question"
echo "  2. LLM asks user and calls answer"
echo "  3. Review runs and returns structured issues"
echo "  4. Marker: VERIFY_ISSUES_REQUIRED when issues exist"
echo "  5. Push allowed only after ready_to_push"
echo ""
echo "============================================"
echo ""

exit 1
