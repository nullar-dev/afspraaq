#!/bin/bash

# =============================================================================
# NullarAI Pre-Push Hook
# 
# This hook BLOCKS git push to ensure code review.
# Copy this file to: .git/hooks/pre-push
# Or use: cp nullar-ai/hooks/pre-push .git/hooks/pre-push
# =============================================================================

if [ "$NULLAR_AI_APPROVED" = "1" ]; then
  exit 0
fi

echo ""
echo "============================================"
echo "🔴 REVIEW REQUIRED"
echo "============================================"
echo ""
echo ">>> FOR LLM: <<<"
echo "   Run: node nullar-ai/src/cli/run.mjs next"
echo "   Then loop with: answer yes|no --user-confirmed \"<user said ...>\""
echo "   If marker VERIFY_ISSUES_REQUIRED appears, validate all issues first"
echo ""
echo ">>> FOR USER: <<<"
echo "   The LLM will guide you through the review."
echo ""
echo "============================================"
echo ""

exit 1
